# Copy to .env and fill in. .env is gitignored — this file is NOT. Never put real
# tokens here; put them in .env.

# Slack USER token (xoxp-...), not a bot token (xoxb-...).
# Slack app → OAuth & Permissions → User Token Scopes → chat:write → install.
SLACK_USER_TOKEN=xoxp-...

# Channel to post in. Channel ID (C01234ABCDE) is safer than #name — names change.
SLACK_CHANNEL=C0BH...

# GitHub classic personal access token with the `repo` scope (private repos) and
# `read:org`. If the org enforces SAML SSO, authorize the token for it too.
GITHUB_TOKEN=ghp_...

# Organization whose repos are watched. Every commit by everyone gets announced.
GITHUB_ORG=

# Repos to stay quiet about, comma-separated, full name.
# GITHUB_EXCLUDE_REPOS=example/noisy-infra, example/generated-sdk

# Announce commits authored by bots (dependabot, renovate...). Off by default.
# INCLUDE_BOTS=false

# If more than this many repos have new commits in one poll, collapse everything
# into a single summary message instead of one message per repo.
# MAX_MESSAGES_PER_POLL=10
