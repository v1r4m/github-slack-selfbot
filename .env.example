# Copy to .env and fill in. .env is gitignored — this file is NOT. Never put real
# tokens here; put them in .env.

# Slack USER token (xoxp-...), not a bot token (xoxb-...).
# Slack app → OAuth & Permissions → User Token Scopes → chat:write → install.
SLACK_USER_TOKEN=xoxp-...

# Channel to post in. Channel ID (C01234ABCDE) is safer than #name — names change.
SLACK_CHANNEL=C01234ABCDE

# GitHub classic personal access token with `repo` + `read:org`.
# If the org enforces SAML SSO, authorize the token for it too.
GITHUB_TOKEN=ghp_...

# Organization whose repos are watched.
GITHUB_ORG=

# Anthropic API key — Claude writes the achievement post.
ANTHROPIC_API_KEY=sk-ant-...

# --- optional ---

# Only my commits get announced (default). Set a different login to track someone
# else, or set ANNOUNCE_ALL=true below to post everyone's commits.
# GITHUB_AUTHOR=eunjinkosilver
# ANNOUNCE_ALL=false

# Catch commits made with an email not linked to your GitHub account (so `author`
# matching by login misses them). Comma-separated. Recommended if commits go missing.
# GITHUB_AUTHOR_EMAILS=you@fnf.co.kr,you@users.noreply.github.com

# Scan every branch, not just the default one (default true). Most feature-branch
# work lives off the default branch, so leaving this on is what catches it.
# SCAN_BRANCHES=true

# Which Claude model writes the post.
# ANTHROPIC_MODEL=claude-opus-4-8

# Emphasize that the work was done with AI tools (default true). Turn off for a
# neutral writeup.
# EMPHASIZE_AI=true

# Extra true context about you/your workflow, woven into the post (e.g. team, what
# you build, that you use Claude Code daily). Keep it factual — the model treats it
# as true and shouldn't be given anything to exaggerate.
# WORK_CONTEXT=프론트엔드 개발자, 사내 회계 시스템(EAS)을 Claude Code로 개발합니다.

# Send commit diffs to Claude for richer, more specific posts. OFF by default —
# this sends private code to Anthropic. Leave off to send only messages + file
# names + counts.
# SEND_DIFF=false

# Skip Claude entirely and post a plain commit list (same as --no-llm).
# USE_LLM=true

# Repos to stay quiet about, comma-separated, full name.
# GITHUB_EXCLUDE_REPOS=example/noisy-infra

# Announce bot commits (dependabot, renovate...). Off by default.
# INCLUDE_BOTS=false

# If more than this many repos have new commits at once, send one plain summary
# instead of a Claude-written post per repo (avoids flooding and API cost).
# MAX_MESSAGES_PER_POLL=10
